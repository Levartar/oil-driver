; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="New to Tallinn!"
config/description="Saad has to drive oil in saudi arabia because the street of Hormuz got closed"
run/main_scene="res://game/ui/screens/Boot.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=120
boot_splash/bg_color=Color(0.141176, 0.141176, 0.141176, 1)
config/icon="uid://dy4vbo0gfyx7a"

[audio]

bus_layout="res://audio/bus_layout.tres"

[autoload]

Settings="*res://game/autoload/Settings.gd"
SaveData="*res://game/autoload/SaveData.gd"
SceneLoader="*res://game/autoload/SceneLoader.gd"
InputManager="*res://game/autoload/InputManager.gd"
GameManager="*res://game/autoload/GameManager.gd"
DialogueManager="*res://game/autoload/DialogueManager.tscn"
DialogueQuest="*uid://b672ftpwqx8rj"

[dialogue_quest]

data_directory="res://game/dialogs"
say_by_name=true

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_quest/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "green",
"res://audio/": "teal",
"res://game/": "blue",
"res://planning/": "red",
"res://translation-i18n/": "pink"
}

