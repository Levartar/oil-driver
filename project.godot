; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="oil-driver"
config/description="Saad has to drive oil in saudi arabia because the street of Hormuz got closed"
run/main_scene="res://game/ui/screens/Boot.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.141176, 0.141176, 0.141176, 1)
config/icon="uid://dy4vbo0gfyx7a"

[audio]

bus_layout="res://audio/bus_layout.tres"

[autoload]

Settings="*res://game/autoload/Settings.gd"
SaveData="*res://game/autoload/SaveData.gd"
SceneLoader="*res://game/autoload/SceneLoader.gd"
InputManager="*res://game/autoload/InputManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

